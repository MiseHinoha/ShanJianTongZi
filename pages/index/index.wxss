/* 全局字体 */
page {
  font-family: 'FZGCustom', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 背景 */
.background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 开始界面 */
.start-screen {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10;
}

.start-btn {
  width: 280rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 36rpx;
  background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
  color: #FFF8DC;
  border: 3rpx solid #CD853F;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.4);
  text-align: center;
  padding: 0;
  font-family: 'FZGCustom', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.start-btn::after {
  border: none;
}

/* 输入界面 */
.input-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 10;
}

.lingpai-wrapper {
  margin-bottom: 40rpx;
}

.lingpai-container {
  position: relative;
  width: 750rpx;
  height: 1100rpx;
}

.lingpai-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 绘制区域 - 覆盖整个令牌木牌区域 */
.write-canvas {
  position: absolute;
  top: 290rpx;
  left: 110rpx;
  width: 500rpx;
  height: 815rpx;
  z-index: 2;
  background: transparent;
}

.input-btns {
  display: flex;
  gap: 40rpx;
  z-index: 10;
}

.rewrite-btn, .submit-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  text-align: center;
  padding: 0;
  font-family: 'FZGCustom', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.rewrite-btn::after, .submit-btn::after {
  border: none;
}

/* 投币动画界面 */
.throw-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10;
}

.throw-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 300rpx;
}

.lingpai-throw {
  position: absolute;
  bottom: 400rpx;
  z-index: 2;
}

.lingpai-img {
  width: 580rpx;
  height: 750rpx;
}

/* 糖饼容器 - 居中 */
.tangbing-wrapper {
  position: absolute;
  bottom: 100rpx;
  z-index: 3;
}

.tangbing {
  width: 180rpx;
  height: 180rpx;
}

/* 等待界面 */
.waiting-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10;
}

.waiting-text {
  font-size: 48rpx;
  color: #FFF8DC;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.8);
  animation: pulse 1.5s ease-in-out infinite;
  font-family: 'FZGCustom', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

/* 结果界面 */
.result-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 10;
}

.result-wrapper {
  margin-bottom: 40rpx;
}

.result-lingpai {
  position: relative;
  width: 750rpx;
  height: 1100rpx;
}

/* 用户绘制的内容 - 使用绘制时的canvas参数 */
.user-drawing {
  position: absolute;
  top: 290rpx;
  left: 110rpx;
  width: 500rpx;
  height: 815rpx;
  z-index: 2;
}

/* 糖饼结果显示 - 位于令牌下方 */
.tangbing-result {
  position: absolute;
  bottom: 88rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 120rpx;
  z-index: 3;
}

.result-dot {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  border: 4rpx solid #5D4037;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
  flex-shrink: 0;
}

.result-dot.red {
  background: linear-gradient(135deg, #DC143C 0%, #8B0000 100%);
}

.result-dot.black {
  background: linear-gradient(135deg, #2F2F2F 0%, #000000 100%);
}

.again-btn {
  width: 280rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 36rpx;
  text-align: center;
  padding: 0;
  font-family: 'FZGCustom', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.again-btn::after {
  border: none;
}

/* 动画类 */
.slide-up {
  animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(100rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

/* 令牌投入动画 - 向上移动到童子嘴部消失 */
.throw-in {
  animation: throwIn 1.2s ease-in-out forwards;
}

@keyframes throwIn {
  0% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
  50% {
    transform: translateY(-100rpx) scale(0.9);
  }
  100% {
    transform: translateY(-600rpx) scale(0.3);
    opacity: 0;
  }
}

/* 糖饼投入动画 - 从底部移动到童子嘴部 */
.tangbing-throw {
  animation: tangbingThrow 1.2s ease-in-out forwards;
}

@keyframes tangbingThrow {
  0% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
  50% {
    transform: translateY(-200rpx) scale(0.9);
  }
  100% {
    transform: translateY(-700rpx) scale(0.3);
    opacity: 0;
  }
}

.drop-down {
  animation: dropDown 0.8s ease-out;
}

@keyframes dropDown {
  0% {
    transform: translateY(-600rpx);
    opacity: 0;
  }
  60% {
    transform: translateY(40rpx);
  }
  80% {
    transform: translateY(-20rpx);
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}
