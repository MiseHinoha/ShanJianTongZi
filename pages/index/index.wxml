<view class="container">
  <!-- 背景图 -->
  <image class="background" src="/Assets/image/ShanJian_Background.png" mode="aspectFill"></image>
  
  <!-- 开始界面 -->
  <view class="start-screen" wx:if="{{gameState === 'start'}}">
    <image class="info-btn" src="/Assets/image/Shanjian_infomation_BTN.png" mode="aspectFit" bindtap="onShowGuide"></image>
    <button class="btn start-btn" bindtap="onStartQuestion">提问</button>
  </view>

  <!-- 玩法说明弹窗 -->
  <view class="guide-overlay {{guideAnim}}" wx:if="{{showGuide}}" bindtap="onCloseGuide">
    <view class="guide-popup {{guideAnim}}" catchtap="onPopupTap">
      <image class="guide-bg" src="/Assets/image/Shanjian_game_comment_new.png" mode="aspectFit"></image>
      <view class="guide-content">
        <view class="guide-section">
          <view class="guide-subtitle">如何提问</view>
          <text class="guide-text">点击「提问」按钮，在令牌上写下你想问的问题，然后点击「提问」提交。</text>
        </view>
        <view class="guide-section">
          <view class="guide-subtitle">三种结果</view>
          <view class="guide-item">
            <view class="guide-dots">
              <view class="guide-dot red"></view>
              <view class="guide-dot red"></view>
            </view>
            <text class="guide-text">童子允诺，此事可行</text>
          </view>
          <view class="guide-item">
            <view class="guide-dots">
              <view class="guide-dot red"></view>
              <view class="guide-dot black"></view>
            </view>
            <text class="guide-text">童子笑而不答，此事尚不确定</text>
          </view>
          <view class="guide-item">
            <view class="guide-dots">
              <view class="guide-dot black"></view>
              <view class="guide-dot black"></view>
            </view>
            <text class="guide-text">童子不允，此事不可行</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 令牌输入界面 -->
  <view class="input-screen" wx:if="{{gameState === 'input'}}">
    <view class="lingpai-wrapper {{lingpaiAnim}}">
      <view class="lingpai-container">
        <image class="lingpai-bg" src="/Assets/image/ShanJian_Lingpai.png" mode="aspectFit"></image>
        <canvas 
          type="2d" 
          id="writeCanvas" 
          class="write-canvas"
          bindtouchstart="onTouchStart"
          bindtouchmove="onTouchMove"
          bindtouchend="onTouchEnd"
        ></canvas>
      </view>
    </view>
    <view class="input-btns">
      <button class="btn rewrite-btn" bindtap="onRewrite">重写</button>
      <button class="btn submit-btn" bindtap="onSubmitQuestion">提问</button>
    </view>
  </view>
  
  <!-- 投币动画界面 -->
  <view class="throw-screen" wx:if="{{gameState === 'throwing'}}">
    <view class="throw-container">
      <view class="lingpai-throw {{throwAnim}}">
        <image class="lingpai-img" src="/Assets/image/ShanJian_Lingpai.png" mode="aspectFit"></image>
      </view>
      <view class="tangbing-wrapper {{tangbingAnim}}">
        <image class="tangbing" src="/Assets/image/ShanJian_Tangbing.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>
  
  <!-- 等待界面 -->
  <view class="waiting-screen" wx:if="{{gameState === 'waiting'}}">
    <text class="waiting-text">童子显灵中...</text>
  </view>
  
  <!-- 结果界面 -->
  <view class="result-screen" wx:if="{{gameState === 'result'}}">
    <view class="result-wrapper {{resultAnim}}">
      <view class="result-lingpai">
        <image class="lingpai-bg" src="/Assets/image/ShanJian_Lingpai.png" mode="aspectFit"></image>
        <!-- 用户绘制的内容 -->
        <image wx:if="{{canvasImage}}" class="user-drawing" src="{{canvasImage}}" mode="aspectFit"></image>
        <!-- 糖饼结果 -->
        <view class="tangbing-result">
          <view class="result-dot {{result[0]}}"></view>
          <view class="result-dot {{result[1]}}"></view>
        </view>
      </view>
    </view>
    <button class="btn again-btn" bindtap="onPlayAgain">再来一次</button>
  </view>
</view>
